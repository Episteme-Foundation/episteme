# Episteme frontend (BFF) configuration.
# Copy to .env.local for local dev, or set in the Vercel project for deploys.

# Base URL of the Episteme Fastify API the BFF proxies to.
#   local backend:   http://localhost:3000
#   deployed:        https://<api-host>     (HTTPS once the ALB has a cert)
# Leave unset to run the frontend on design fixtures only.
EPISTEME_API_URL=

# API key the BFF sends as `x-api-key`. Mint a dedicated frontend key and add it
# to the backend's API_KEYS list so it can be rotated independently. Never expose
# this to the browser — it is read server-side only.
EPISTEME_API_KEY=
