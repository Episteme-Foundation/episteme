# Episteme frontend (BFF) configuration.
# Copy to .env.local for local dev, or set in the Vercel project for deploys.

# Base URL of the Episteme Fastify API the BFF proxies to.
#   local backend:   http://localhost:3000
#   deployed:        https://<api-host>     (HTTPS once the ALB has a cert)
# Leave unset to run the frontend on design fixtures only.
EPISTEME_API_URL=

# API key the BFF sends as `x-api-key`. Mint a dedicated frontend key and add it
# to the backend's API_KEYS list so it can be rotated independently. Never expose
# this to the browser — it is read server-side only.
EPISTEME_API_KEY=

# --- Accounts / sign-in (issue #70) ------------------------------------------
# Auth.js session encryption secret. Generate with: openssl rand -base64 32
# Required in production; a fixed dev fallback is used locally.
AUTH_SECRET=

# OAuth providers — set a pair to enable that provider on /signin.
# GitHub: create an OAuth app with callback <site>/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
# Google: callback <site>/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Development-only username login (never active in production builds).
# Defaults to on in dev when no OAuth provider is configured; force with
# true/false.
AUTH_DEV_LOGIN=

# --- Contact form (issue #81) -------------------------------------------------
# Delivery for /about's contact form via SES (/api/contact). Both must be set
# or the form returns 503. CONTACT_FROM_EMAIL must be an SES-verified sender;
# standard AWS credentials/region env vars must also be available.
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=
