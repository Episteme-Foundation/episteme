# Episteme Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# ENVIRONMENT
# =============================================================================
ENVIRONMENT=development  # development | staging | production

# =============================================================================
# DATABASE
# =============================================================================
# PostgreSQL with pgvector
DATABASE_URL=postgres://episteme:episteme_dev@localhost:5432/episteme

# =============================================================================
# AWS
# =============================================================================
AWS_REGION=us-east-1

# =============================================================================
# API SETTINGS
# =============================================================================
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
# Comma-separated API keys. Bind a key to a contributor identity with
# "key:contributor_external_id" — contribution/appeal endpoints act as the
# contributor bound to the presented key (issue #10); unbound keys can read but
# not contribute. With no keys configured, auth is skipped and contributions
# act as the "dev-local" contributor.
API_KEYS=dev-api-key:dev-local

# =============================================================================
# LLM SETTINGS
# =============================================================================
# Override default models. Use Anthropic API model IDs (e.g. claude-fable-5,
# claude-sonnet-5, claude-haiku-4-5-20251001), NOT Bedrock "us.anthropic.*" IDs.
# Production runs the load-bearing agents on Fable 5 (deep-judgment roles where
# the capability jump matters; priced above Opus, so scoped to these — issue #77).
# Note: Fable 5 requires the org to allow 30-day data retention (ZDR orgs get a
# 400 on every request).
# STEWARD_MODEL=claude-fable-5
# CURATOR_MODEL=claude-fable-5
# AUDIT_MODEL=claude-fable-5
# ARBITRATION_MODEL=claude-fable-5
# MATCHER_MODEL=claude-haiku-4-5-20251001
# GOVERNANCE_MODEL=claude-sonnet-5

# =============================================================================
# PROCESSING SETTINGS
# =============================================================================
# MAX_DECOMPOSITION_DEPTH=5
# MATCHING_SIMILARITY_THRESHOLD=0.85
# Quantity caps to bound graph fan-out (0 = unlimited). Turn these DOWN for fast,
# cheap iteration on prompts; leave at 0 for a faithful full run.
# EXTRACTION_MAX_CLAIMS=0       # most-central claims per document
# MAX_SUBCLAIMS_PER_CLAIM=0     # subclaims per decomposition (tree width)

# =============================================================================
# GOVERNANCE SETTINGS
# =============================================================================
# ENABLE_CONTRIBUTIONS=false
# ESCALATION_CONFIDENCE_THRESHOLD=0.6
# AUDIT_SAMPLE_RATE=0.05

# =============================================================================
# SQS QUEUES (production only -- local dev uses in-memory queues)
# =============================================================================
# SQS_CLAIM_PIPELINE_QUEUE=
# SQS_URL_EXTRACTION_QUEUE=
# SQS_CONTRIBUTION_QUEUE=
# SQS_ARBITRATION_QUEUE=
# SQS_STEWARD_QUEUE=
# SQS_AUDIT_QUEUE=
