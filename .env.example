# Episteme Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# ENVIRONMENT
# =============================================================================
ENVIRONMENT=development  # development | staging | production

# =============================================================================
# DATABASE
# =============================================================================
# PostgreSQL with pgvector
DATABASE_URL=postgres://episteme:episteme_dev@localhost:5432/episteme

# =============================================================================
# AWS
# =============================================================================
AWS_REGION=us-east-1

# =============================================================================
# API SETTINGS
# =============================================================================
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
API_KEY=dev-api-key

# =============================================================================
# LLM SETTINGS (AWS Bedrock)
# =============================================================================
# Override default models (all use Bedrock model IDs)
# LLM_MODEL=us.anthropic.claude-sonnet-4-20250514
# GOVERNANCE_MODEL=us.anthropic.claude-sonnet-4-20250514
# ARBITRATION_MODEL=us.anthropic.claude-sonnet-4-20250514

# =============================================================================
# PROCESSING SETTINGS
# =============================================================================
# MAX_DECOMPOSITION_DEPTH=5
# MATCHING_SIMILARITY_THRESHOLD=0.85

# =============================================================================
# GOVERNANCE SETTINGS
# =============================================================================
# ENABLE_CONTRIBUTIONS=false
# ENABLE_MULTI_MODEL_CONSENSUS=false
# ESCALATION_CONFIDENCE_THRESHOLD=0.6
# AUDIT_SAMPLE_RATE=0.05

# =============================================================================
# SQS QUEUES (production only -- local dev uses in-memory queues)
# =============================================================================
# SQS_CLAIM_PIPELINE_QUEUE=
# SQS_URL_EXTRACTION_QUEUE=
# SQS_CONTRIBUTION_QUEUE=
# SQS_ARBITRATION_QUEUE=
# SQS_STEWARD_QUEUE=
# SQS_AUDIT_QUEUE=
