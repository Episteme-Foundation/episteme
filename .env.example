# Episteme Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# ENVIRONMENT
# =============================================================================
ENVIRONMENT=development  # development | staging | production

# =============================================================================
# LLM SETTINGS
# =============================================================================
# Required: Get your API key from https://console.anthropic.com/
LLM_ANTHROPIC_API_KEY=sk-ant-...

# Optional: Override default models
# LLM_EXTRACTION_MODEL=claude-sonnet-4-20250514
# LLM_MATCHING_MODEL=claude-sonnet-4-20250514
# LLM_DECOMPOSITION_MODEL=claude-sonnet-4-20250514
# LLM_ASSESSMENT_MODEL=claude-sonnet-4-20250514
# LLM_GOVERNANCE_MODEL=claude-sonnet-4-20250514
# LLM_ARBITRATION_MODEL=claude-opus-4-5-20250101

# =============================================================================
# DATABASE SETTINGS
# =============================================================================
# Neo4j (Graph Database)
DB_NEO4J_URI=bolt://localhost:7687
DB_NEO4J_USER=neo4j
DB_NEO4J_PASSWORD=episteme_dev

# PostgreSQL (Document Store)
DB_POSTGRES_HOST=localhost
DB_POSTGRES_PORT=5432
DB_POSTGRES_USER=episteme
DB_POSTGRES_PASSWORD=episteme_dev
DB_POSTGRES_DB=episteme

# Redis (Cache/Broker)
DB_REDIS_URL=redis://localhost:6379/0

# =============================================================================
# VECTOR DATABASE SETTINGS
# =============================================================================
# Provider: "qdrant" for local development, "pinecone" for production
VECTOR_PROVIDER=qdrant

# Qdrant (local development)
VECTOR_QDRANT_HOST=localhost
VECTOR_QDRANT_PORT=6333
VECTOR_QDRANT_COLLECTION_NAME=claims

# Pinecone (production) - uncomment and fill in for production
# VECTOR_PROVIDER=pinecone
# VECTOR_PINECONE_API_KEY=your-pinecone-api-key
# VECTOR_PINECONE_ENVIRONMENT=us-east-1
# VECTOR_PINECONE_INDEX_NAME=episteme-claims

# =============================================================================
# PROCESSING SETTINGS
# =============================================================================
# PROCESSING_MAX_DECOMPOSITION_DEPTH=5
# PROCESSING_DECOMPOSITION_CONFIDENCE_THRESHOLD=0.7
# PROCESSING_MATCHING_SIMILARITY_THRESHOLD=0.85
# PROCESSING_MATCHING_TOP_K=20

# =============================================================================
# API SETTINGS
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true
API_RELOAD=true

# CORS origins (comma-separated for multiple)
# API_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# ENABLE_CONTRIBUTIONS=true
# ENABLE_ARBITRATION=true
# ENABLE_MULTI_MODEL_CONSENSUS=false
