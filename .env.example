# Episteme Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# ENVIRONMENT
# =============================================================================
ENVIRONMENT=development  # development | staging | production

# =============================================================================
# DATABASE
# =============================================================================
# PostgreSQL with pgvector
DATABASE_URL=postgres://episteme:episteme_dev@localhost:5432/episteme

# =============================================================================
# AWS
# =============================================================================
AWS_REGION=us-east-1

# =============================================================================
# API SETTINGS
# =============================================================================
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
# Comma-separated operator API keys (bootstrap / first-party). Bind a key to a
# contributor identity with "key:contributor_external_id" — contribution/appeal
# endpoints act as the contributor bound to the presented key (issue #10).
# Env keys are SERVICE-TRUSTED: they may act on behalf of a signed-in user via
# the x-acting-user header (this is how the web frontend's BFF authenticates).
# End-user keys are DB-backed and minted from the dashboard (issue #70) — env
# keys are only for operators and first-party services.
# With no keys configured (non-production only), auth is bypassed and requests
# act as the local "dev:local" account.
API_KEYS=dev-api-key:dev:local

# =============================================================================
# ACCOUNTS / METERING (issue #70)
# =============================================================================
# Monthly free-tier grant for METERED (agentic/LLM-backed) usage, in USD of
# derived token cost. Non-agentic reads are never metered. 0 disables the
# trial entirely (agentic endpoints return 402 until credits exist).
# FREE_TIER_MONTHLY_USD=5
# Per-key rate limit on agentic endpoints (requests/hour, 0 = unlimited).
# AGENTIC_RATE_LIMIT_PER_HOUR=30

# =============================================================================
# LLM SETTINGS
# =============================================================================
# Override default models. Use Anthropic API model IDs (e.g. claude-opus-4-8,
# claude-sonnet-4-6, claude-haiku-4-5-20251001), NOT Bedrock "us.anthropic.*" IDs.
# Production runs the load-bearing agents on Opus:
# STEWARD_MODEL=claude-opus-4-8
# CURATOR_MODEL=claude-opus-4-8
# AUDIT_MODEL=claude-opus-4-8
# ARBITRATION_MODEL=claude-opus-4-8
# MATCHER_MODEL=claude-haiku-4-5-20251001
# GOVERNANCE_MODEL=claude-sonnet-4-6

# =============================================================================
# PROCESSING SETTINGS
# =============================================================================
# MAX_DECOMPOSITION_DEPTH=5
# MATCHING_SIMILARITY_THRESHOLD=0.85
# Quantity caps to bound graph fan-out (0 = unlimited). Turn these DOWN for fast,
# cheap iteration on prompts; leave at 0 for a faithful full run.
# EXTRACTION_MAX_CLAIMS=0       # most-central claims per document
# MAX_SUBCLAIMS_PER_CLAIM=0     # subclaims per decomposition (tree width)

# =============================================================================
# GOVERNANCE SETTINGS
# =============================================================================
# ENABLE_CONTRIBUTIONS=false
# ESCALATION_CONFIDENCE_THRESHOLD=0.6
# AUDIT_SAMPLE_RATE=0.05

# =============================================================================
# SQS QUEUES (production only -- local dev uses in-memory queues)
# =============================================================================
# SQS_CLAIM_PIPELINE_QUEUE=
# SQS_URL_EXTRACTION_QUEUE=
# SQS_CONTRIBUTION_QUEUE=
# SQS_ARBITRATION_QUEUE=
# SQS_STEWARD_QUEUE=
# SQS_AUDIT_QUEUE=
